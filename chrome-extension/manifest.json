{
  "manifest_version": 3,
  "name": "X Cookie Exporter",
  "version": "1.0",
  "description": "x.com の Cookie を安全にクリップボードへコピーする",
  "permissions": ["cookies", "clipboardWrite"],
  "host_permissions": ["*://*.x.com/*"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "X Cookie Exporter"
  }
}

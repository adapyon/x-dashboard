{
  "manifest_version": 3,
  "name": "X Cookie Exporter",
  "version": "1.1",
  "description": "x.com / twitter.com の Cookie を安全にコピーする",
  "permissions": ["cookies", "clipboardWrite"],
  "host_permissions": [
    "*://*.x.com/*",
    "*://*.twitter.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "X Cookie Exporter"
  }
}
